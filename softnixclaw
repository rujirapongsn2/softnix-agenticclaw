#!/bin/bash

# Softnix AgenticClaw Unified Management CLI
# Usage: ./softnixclaw {admin|update|install} [subcommand]

set -e

# --- Configuration ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$SCRIPT_DIR"
ADMIN_HOME="$HOME/.softnix/admin"
LOG_DIR="$ADMIN_HOME/logs"
RUN_DIR="$ADMIN_HOME/run"
LOG_FILE="$LOG_DIR/admin.log"
PID_FILE="$RUN_DIR/admin.pid"
SERVICE_NAME="softnix-admin"
SYSTEMD_USER_DIR="$HOME/.config/systemd/user"
ADMIN_HOST="${SOFTNIX_ADMIN_HOST:-0.0.0.0}"
ADMIN_PORT="${SOFTNIX_ADMIN_PORT:-18880}"
if [ -x "$PROJECT_ROOT/.venv/bin/python" ]; then
    PYTHON_HELPER="$PROJECT_ROOT/.venv/bin/python"
elif command -v python3 &> /dev/null; then
    PYTHON_HELPER="$(command -v python3)"
else
    echo "Error: 'python3' command not found. Please install Python first."
    exit 1
fi

# Ensure directories exist
mkdir -p "$LOG_DIR" "$RUN_DIR"

# Detect nanobot command
if [ -x "$PROJECT_ROOT/.venv/bin/nanobot" ]; then
    PYTHON_CMD="$PROJECT_ROOT/.venv/bin/nanobot"
elif command -v nanobot &> /dev/null; then
    PYTHON_CMD="$(command -v nanobot)"
else
    echo "Error: 'nanobot' command not found. Please install the package first."
    exit 1
fi

# --- Helper Functions ---

is_systemd_active() {
    if command -v systemctl &> /dev/null; then
        if systemctl --user list-unit-files | grep -q "$SERVICE_NAME.service"; then
            return 0
        fi
    fi
    return 1
}

get_pid() {
    if [ -f "$PID_FILE" ]; then
        cat "$PID_FILE"
    else
        echo ""
    fi
}

collect_registry_images() {
    local registry_path="$ADMIN_HOME/instances.json"
    if [ ! -f "$registry_path" ]; then
        echo "softnixclaw:latest"
        return 0
    fi

    "$PYTHON_HELPER" - "$registry_path" <<'PY'
import json
from pathlib import Path
import sys

from nanobot.config.loader import load_config

registry_path = Path(sys.argv[1]).expanduser()
images: set[str] = set()

try:
    data = json.loads(registry_path.read_text(encoding="utf-8"))
except Exception:
    data = {"instances": []}

for item in data.get("instances", []):
    image = ""
    config_path = Path(str(item.get("config") or "")).expanduser()
    if config_path.exists():
        try:
            config = load_config(config_path)
            image = str(getattr(config.runtime.sandbox, "image", "") or "").strip()
        except Exception:
            image = ""
    if not image:
        runtime = item.get("runtime")
        if isinstance(runtime, dict):
            sandbox = runtime.get("sandbox")
            if isinstance(sandbox, dict):
                image = str(sandbox.get("image") or "").strip()
    if image:
        images.add(image)

if not images:
    images.add("softnixclaw:latest")

for image in sorted(images):
    print(image)
PY
}

collect_running_instances() {
    local registry_path="$ADMIN_HOME/instances.json"
    if [ ! -f "$registry_path" ]; then
        return 0
    fi

    "$PYTHON_HELPER" - "$registry_path" <<'PY'
import json
import subprocess
from pathlib import Path
import sys

registry_path = Path(sys.argv[1]).expanduser()
try:
    data = json.loads(registry_path.read_text(encoding="utf-8"))
except Exception:
    sys.exit(0)

for item in data.get("instances", []):
    lifecycle = item.get("lifecycle")
    if not isinstance(lifecycle, dict):
        continue
    status_command = lifecycle.get("status")
    restart_command = lifecycle.get("restart")
    if not isinstance(status_command, list) or not isinstance(restart_command, list):
        continue

    cwd = item.get("cwd")
    cwd_path = str(Path(cwd).expanduser()) if cwd else None
    try:
        probe = subprocess.run(
            status_command,
            cwd=cwd_path,
            capture_output=True,
            text=True,
            timeout=30,
            check=False,
        )
    except Exception:
        continue

    if probe.returncode == 0:
        payload = {
            "id": item.get("id"),
            "name": item.get("name"),
            "cwd": cwd_path,
            "restart": restart_command,
        }
        print(json.dumps(payload, ensure_ascii=False))
PY
}

restart_running_instances() {
    local running_instances
    running_instances="$(collect_running_instances)"
    if [ -z "$running_instances" ]; then
        echo "   No running instances found."
        return 0
    fi

    RUNNING_INSTANCES_PAYLOAD="$running_instances" "$PYTHON_HELPER" - <<'PY'
import json
import subprocess
import os
import sys

payloads = [line for line in os.environ.get("RUNNING_INSTANCES_PAYLOAD", "").splitlines() if line.strip()]
if not payloads:
    print("   No running instances found.")
    raise SystemExit(0)

failures = []
restarted = 0
for raw in payloads:
    item = json.loads(raw)
    instance_id = item.get("id") or "unknown"
    instance_name = item.get("name") or instance_id
    restart_command = item.get("restart")
    cwd = item.get("cwd") or None
    if not isinstance(restart_command, list) or not restart_command:
        continue

    print(f"   Restarting running instance: {instance_id} ({instance_name})")
    try:
        result = subprocess.run(
            restart_command,
            cwd=cwd,
            capture_output=True,
            text=True,
            timeout=120,
            check=False,
        )
    except Exception as exc:
        failures.append(f"{instance_id}: {exc}")
        continue

    if result.returncode == 0:
        restarted += 1
        stdout = (result.stdout or "").strip()
        if stdout:
            print(f"      {stdout}")
    else:
        stderr = (result.stderr or result.stdout or "").strip()
        failures.append(f"{instance_id}: exit {result.returncode} - {stderr[:300]}")

print(f"   Restarted {restarted} running instance(s).")
if failures:
    print("   Some running instances failed to restart:")
    for failure in failures:
        print(f"      - {failure}")
    raise SystemExit(1)
PY
}

classify_update_scope() {
    local changed_files="$1"
    local rebuild_var="$2"
    local restart_var="$3"
    local rebuild_image=0
    local restart_instances=0

    while IFS= read -r file; do
        [ -n "$file" ] || continue
        case "$file" in
            README*|*.md|docs/*|nanobot/admin/static/*|tests/*|.github/*)
                ;;
            nanobot/admin/*|softnixclaw|scripts/*)
                ;;
            Dockerfile|pyproject.toml|uv.lock|bridge/*|nanobot/*)
                rebuild_image=1
                restart_instances=1
                ;;
            *)
                ;;
        esac
    done <<EOF
$changed_files
EOF

    eval "$rebuild_var=$rebuild_image"
    eval "$restart_var=$restart_instances"
}

start_admin() {
    echo "Starting Softnix Admin..."
    
    if is_systemd_active; then
        echo "Using Systemd service..."
        systemctl --user start "$SERVICE_NAME"
        echo "Service started. Check status with: systemctl --user status $SERVICE_NAME"
    else
        PID=$(get_pid)
        if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
            echo "Softnix Admin is already running (PID: $PID)"
        else
            nohup "$PYTHON_CMD" softnix-admin --host "$ADMIN_HOST" --port "$ADMIN_PORT" > "$LOG_FILE" 2>&1 &
            NEW_PID=$!
            echo "$NEW_PID" > "$PID_FILE"
            echo "Softnix Admin started in background (PID: $NEW_PID)"
            echo "Logs: $LOG_FILE"
        fi
    fi
    echo "Dashboard URL: http://$ADMIN_HOST:$ADMIN_PORT"
}

stop_admin() {
    echo "Stopping Softnix Admin..."
    
    if is_systemd_active; then
        echo "Using Systemd service..."
        systemctl --user stop "$SERVICE_NAME"
    else
        PID=$(get_pid)
        if [ -n "$PID" ]; then
            if kill -0 "$PID" 2>/dev/null; then
                kill "$PID"
                # Wait for process to exit
                TIMEOUT=10
                while kill -0 "$PID" 2>/dev/null && [ $TIMEOUT -gt 0 ]; do
                    sleep 1
                    ((TIMEOUT--))
                done
                if kill -0 "$PID" 2>/dev/null; then
                    echo "Force killing..."
                    kill -9 "$PID"
                fi
                echo "Stopped."
            else
                echo "Process not running but PID file exists. Cleaning up."
            fi
            rm -f "$PID_FILE"
        else
            echo "Softnix Admin is not running (no PID file)."
        fi
    fi
}

restart_admin() {
    echo "Restarting Softnix Admin..."
    stop_admin
    sleep 2
    start_admin
}

status_admin() {
    echo "--- Softnix Admin Status ---"
    
    if is_systemd_active; then
        systemctl --user status "$SERVICE_NAME" --no-pager
    else
        PID=$(get_pid)
        if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
            echo "Status: RUNNING"
            echo "PID: $PID"
            echo "Uptime: $(ps -p "$PID" -o etime=)"
        else
            echo "Status: STOPPED"
        fi
    fi
    
    echo ""
    echo "--- Recent Logs ---"
    if [ -f "$LOG_FILE" ]; then
        tail -n 10 "$LOG_FILE"
    else
        echo "No log file found at $LOG_FILE"
    fi
}

install_service() {
    echo "Installing Systemd Service for Softnix Admin..."
    
    if ! command -v systemctl &> /dev/null; then
        echo "Error: 'systemctl' not found. This command is only for Linux systems with Systemd."
        exit 1
    fi
    
    # Create user systemd directory
    mkdir -p "$SYSTEMD_USER_DIR"
    
    SERVICE_FILE="$SYSTEMD_USER_DIR/$SERVICE_NAME.service"
    echo "Creating service file at: $SERVICE_FILE"
    
    cat > "$SERVICE_FILE" <<EOF
[Unit]
Description=Softnix AgenticClaw Admin Service
After=network.target

[Service]
Type=simple
WorkingDirectory=$PROJECT_ROOT
ExecStart=$PYTHON_CMD softnix-admin --host $ADMIN_HOST --port $ADMIN_PORT
Restart=always
RestartSec=10
StandardOutput=append:$LOG_FILE
StandardError=append:$LOG_FILE

[Install]
WantedBy=default.target
EOF

    echo "Reloading systemd daemon..."
    systemctl --user daemon-reload
    
    echo "Enabling service to start on boot..."
    systemctl --user enable "$SERVICE_NAME"
    
    echo "Enabling user lingering (to keep service running after logout)..."
    if command -v loginctl &> /dev/null; then
        loginctl enable-linger "$USER" || echo "Warning: Could not enable lingering. Service might stop when you logout."
    else
        echo "Warning: 'loginctl' not found. Service might stop when you logout."
    fi
    
    echo "Starting service now..."
    systemctl --user start "$SERVICE_NAME"
    
    echo "✅ Installation Complete! Softnix Admin is now running as a service."
    echo "Manage it with: ./softnixclaw admin {start|stop|restart|status}"
}

update_project() {
    echo "Updating Softnix AgenticClaw..."

    # 1. Backup critical data
    echo "1. Backing up configuration..."
    if [ -f "$ADMIN_HOME/instances.json" ]; then
        BACKUP_FILE="$ADMIN_HOME/instances.json.bak.$(date +%Y%m%d%H%M)"
        cp "$ADMIN_HOME/instances.json" "$BACKUP_FILE"
        echo "   Backup saved to: $BACKUP_FILE"
    fi

    local before_head=""
    local after_head=""
    local changed_files=""
    local rebuild_image=0
    local restart_instances=0

    if [ -d ".git" ]; then
        before_head="$(git rev-parse HEAD)"
    fi

    # 2. Pull latest changes
    echo "2. Pulling latest changes from git..."
    if [ -d ".git" ]; then
        if ! git pull; then
            echo "❌ Error: git pull failed"
            exit 1
        fi
        after_head="$(git rev-parse HEAD)"
        if [ -n "$before_head" ] && [ "$before_head" != "$after_head" ]; then
            changed_files="$(git diff --name-only "$before_head" "$after_head")"
            classify_update_scope "$changed_files" rebuild_image restart_instances
        fi
    else
        echo "⚠️ Warning: Not a git repository. Skipping git pull."
    fi

    if [ "$rebuild_image" -eq 1 ]; then
        echo "   Runtime-affecting changes detected; sandbox image rebuild is required."
    fi
    if [ "$restart_instances" -eq 1 ]; then
        echo "   Running instances will be restarted after the update."
    fi

    # 3. Update dependencies with uv (preferred) or pip
    echo "3. Updating dependencies..."
    if command -v uv &> /dev/null && [ -f "$PROJECT_ROOT/uv.lock" ]; then
        echo "   Using uv (recommended)..."
        if ! uv pip install -e .; then
            echo "❌ Error: uv pip install failed"
            exit 1
        fi
    else
        echo "   Using pip (uv not found or no lock file)..."
        if ! pip install -e .; then
            echo "❌ Error: pip install failed"
            exit 1
        fi
    fi

    # 4. Rebuild sandbox images if runtime code changed
    if [ "$rebuild_image" -eq 1 ]; then
        echo "4. Rebuilding sandbox image(s)..."
        while IFS= read -r sandbox_image; do
            [ -n "$sandbox_image" ] || continue
            echo "   Building $sandbox_image"
            if ! docker build -t "$sandbox_image" .; then
                echo "❌ Error: docker build failed for $sandbox_image"
                exit 1
            fi
        done <<EOF
$(collect_registry_images)
EOF
    else
        echo "4. Sandbox image rebuild not required."
    fi

    # 5. Restart service
    echo "5. Restarting service..."
    restart_admin

    # 6. Restart running instances if needed
    if [ "$restart_instances" -eq 1 ]; then
        echo "6. Restarting running instances..."
        if ! restart_running_instances; then
            echo "⚠️ One or more instances failed to restart. Check logs above."
        fi
    else
        echo "6. Instance restart not required."
    fi

    # 7. Verify service is running
    echo "7. Verifying service health..."
    sleep 5
    if curl -s --max-time 10 "http://$ADMIN_HOST:$ADMIN_PORT/admin/health" > /dev/null 2>&1; then
        echo "✅ Update Complete! Service is healthy."
    else
        echo "⚠️ Update Complete but service health check failed. Check logs: $LOG_FILE"
    fi
}

# --- Main Command Handler ---

COMMAND=$1
SUBCOMMAND=$2

case "$COMMAND" in
    admin)
        case "$SUBCOMMAND" in
            start)
                start_admin
                ;;
            stop)
                stop_admin
                ;;
            restart)
                restart_admin
                ;;
            status)
                status_admin
                ;;
            *)
                echo "Usage: $0 admin {start|stop|restart|status}"
                exit 1
                ;;
        esac
        ;;
    install)
        install_service
        ;;
    update)
        update_project
        ;;
    *)
        echo "Softnix AgenticClaw Management Tool"
        echo "Usage:"
        echo "  $0 admin {start|stop|restart|status}  - Manage the Admin Service"
        echo "  $0 install                            - Install as Systemd Service (Linux Auto-Start)"
        echo "  $0 update                             - Update code and restart"
        exit 1
        ;;
esac
